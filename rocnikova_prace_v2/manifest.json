{
  "manifest_version": 3,
  "name": "FoxPass",
  "version": "2.5",
  "description": "Symmetrically encrypted password manager extension for Firefox browser",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://fxevhmvpwgejricjjmkm.supabase.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://fxevhmvpwgejricjjmkm.supabase.co"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "foxpass.test@my.id",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.jpg"
  }
}